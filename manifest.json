{
  "manifest_version": 3,
  "name": "PageChat AI - Chat with Any Webpage",
  "version": "2.0.0",
  "description": "Chat with any webpage using AI. Opens a sidebar directly on the page with well-formatted responses.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://openrouter.ai/*"],
  "action": {
    "default_title": "Toggle PageChat AI Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "content/sidebar.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["lib/marked.min.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}