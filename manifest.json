{
  "manifest_version": 3,
  "name": "PageChat AI - Chat with Any Webpage",
  "version": "1.0.0",
  "description": "Chat with any webpage using AI. Ask questions about the page content with OpenRouter models.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://openrouter.ai/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}